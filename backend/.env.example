# Local development template. Do not commit backend/.env with real secrets.

APP_PEPPER=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-another-long-random-secret

# Supabase transaction-mode pooler. Replace [YOUR-PASSWORD] with your database password.
DATABASE_URL=postgresql://postgres.glxbdziveyazlrcpfldw:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: Supabase session-mode pooler, useful for migrations/manual admin tasks.
DIRECT_URL=postgresql://postgres.glxbdziveyazlrcpfldw:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

ALLOWED_ORIGINS=http://localhost:8000,https://secure-registration-login-system.onrender.com
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
MAX_FAILED_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
